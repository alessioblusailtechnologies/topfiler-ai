# ===========================================================================
# topFiler3 — variabili d'ambiente (validate con Zod all'avvio: src/env.ts)
# Tre credenziali DISTINTE e mai mescolate (vedi README → Sicurezza):
#   1. Oracle read-only        → solo INGESTION (lettura BLOB sorgente)
#   2. Supabase service role    → solo INGESTION/STORAGE (scrittura metadati/chunk/file)
#   3. Postgres topfiler_final_ai_readonly → solo TOOL text_to_sql (SELECT su documenti)
# ===========================================================================

# --- Anthropic (agente Mastra + chiamate dirette di servizio) --------------
ANTHROPIC_API_KEY=
# Modello dell'agente conversazionale, via model router di Mastra: "anthropic/<id>"
AGENT_MODEL=anthropic/claude-sonnet-4-6
# Modelli per le chiamate dirette @anthropic-ai/sdk in ingestion / text_to_sql
CLASSIFY_MODEL=claude-haiku-4-5
EXTRACT_MODEL=claude-sonnet-4-6
SQLGEN_MODEL=claude-sonnet-4-6

# --- Mistral (embedding via REST + OCR via SDK) ----------------------------
MISTRAL_API_KEY=
MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_EMBED_DIMS=1024
MISTRAL_OCR_MODEL=mistral-ocr-latest

# --- Supabase (service role: ingestion + storage) --------------------------
SUPABASE_URL=
# La service_role key del progetto Supabase (STESSO valore del web).
# Alias legacy accettato: SUPABASE_SERVICE_KEY.
SUPABASE_SERVICE_ROLE_KEY=
# Fallback usato se manca la service role key (lecito: RLS disabilitato sulle tabelle).
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=topfiler-final-ai-documenti

# --- SMTP (invio email — tool send_email) ----------------------------------
# Default su mail.com. Attiva prima l'accesso POP3/IMAP nelle impostazioni dell'account.
# Il mittente coincide con SMTP_USER (mail.com/GMX non consentono spoofing del "from").
# Host per provider: mail.com → smtp.mail.com | GMX.com → mail.gmx.com | GMX.net → mail.gmx.net
SMTP_HOST=smtp.mail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=topFiler3

# --- Postgres read-only (tool text_to_sql) ---------------------------------
# Connection string del POOLER Supabase con utente "topfiler_final_ai_readonly".
# Es: postgresql://topfiler_final_ai_readonly:PWD@aws-0-eu-...pooler.supabase.com:6543/postgres
READONLY_DATABASE_URL=
READONLY_STATEMENT_TIMEOUT_MS=10000

# --- Postgres per la memory di Mastra (storage history conversazione) ------
# Può essere la connection string Supabase con un ruolo che scrive sullo schema "mastra".
MASTRA_DATABASE_URL=

# --- Oracle (sorgente documenti, sola lettura — solo ingestion) ------------
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECTION_STRING=host:1521/service

# --- Ingestion -------------------------------------------------------------
INGEST_SOURCE=filesystem
DOCS_DIR=../topfiler-ai/docs_in_db
OCR_ENABLED=true
INGEST_CONCURRENCY=3
INGEST_BATCH_SIZE=50
CONFIDENCE_THRESHOLD=0.85

# --- Server ----------------------------------------------------------------
PORT=3000
