# topFiler3 web (Next.js) — variabili d'ambiente
# Supabase: SOLO lato server (persistenza chat + signed URL download). Mai esposte al browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Stesso bucket usato dal backend (deve coincidere).
SUPABASE_STORAGE_BUCKET=topfiler-final-ai-documenti
# URL del backend topFiler3 (Hono). In locale: http://localhost:3100.
# Su Render: l'host del servizio backend (lo schema https viene aggiunto in automatico).
TOPFILER_BACKEND_URL=http://localhost:3100
